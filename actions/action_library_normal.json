            "jungle_tropical",
            "desert_sand",
            "mountain_rocky",
            "canyon_valley",
            "plains_grassland",
            "swamp_wetland",
            "cave_underground",
            "volcano_lava",
            "space_station",
            "alien_planet",
            "fantasy_castle",
            "medieval_town",
            "cyberpunk_city",
            "post_apocalyptic",
            "haunted_mansion",
            "temple_shrine",
            "palace_interior",
            "office_modern",
            "bedroom_interior"
          ],
          "required": true,
          "description": "Current physical location type"
        },
        "target_location": {
          "type": "enum",
          "values": [
