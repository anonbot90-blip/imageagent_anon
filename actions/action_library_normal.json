            "suburban_neighborhood",
            "rural_village",
            "industrial_zone",
            "commercial_district",
            "beach_coast",
            "tropical_island",
            "ocean_open_water",
            "underwater_reef",
            "arctic_ice",
            "forest_temperate",
            "jungle_tropical",
            "desert_sand",
            "mountain_rocky",
            "canyon_valley",
            "plains_grassland",
            "swamp_wetland",
            "cave_underground",
            "volcano_lava",
            "space_station",
            "alien_planet",
            "fantasy_castle",
            "medieval_town",
            "cyberpunk_city",
            "post_apocalyptic",
            "haunted_mansion",
            "temple_shrine",
            "palace_interior",
            "office_modern",
            "bedroom_interior"
          ],
          "required": true,
          "description": "Desired physical location type"
        },
        "replace_mode": {
          "type": "enum",
          "values": [
            "partial",
            "complete"
          ],
          "default": "complete",
          "description": "Partial blends old with new, complete fully replaces"
        },
        "preserve_foreground": {
          "type": "boolean",
          "default": true,
          "description": "Keep main subjects unchanged while transforming environment"
        },
        "description": {
          "type": "string",
          "required": true,
          "description": "Natural language description of location change"
        }
      },
      "does_not_handle": [
        "Architecture style",
        "Time period",
        "Mood",
        "Color palette",
        "Weather"
      ],
      "example": {
        "source_location": "urban_city",
        "target_location": "beach_coast",
        "replace_mode": "complete",
        "preserve_foreground": true,
        "description": "Transform urban city street into tropical beach coastline"
      }
    },
