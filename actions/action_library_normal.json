        "sky_color": {
          "type": "string",
          "default": "auto",
          "description": "Sky color palette for the time (auto-determined from time, or specify)"
        },
        "shadow_direction": {
          "type": "enum",
          "values": [
            "east",
            "southeast",
            "south",
            "southwest",
            "west",
            "overhead",
            "none"
          ],
          "default": "auto",
          "description": "Direction of shadows based on sun/moon position"
        },
        "description": {
          "type": "string",
          "required": true,
          "description": "Natural language description of time change"
        }
      },
      "does_not_handle": [
        "Weather",
        "Mood",
        "Season",
        "Artificial lighting"
