    {
      "id": "time_of_day",
      "name": "Time of Day",
      "description": "Change natural lighting based on sun/moon position (what time is it)",
      "category": "temporal_environmental",
      "parameters": {
        "source_time": {
          "type": "enum",
          "values": [
            "pre_dawn",
            "sunrise_golden",
            "morning_bright",
            "midday_overhead",
            "afternoon_warm",
            "golden_hour_sunset",
            "dusk_twilight",
            "blue_hour",
            "night_moonlit",
            "midnight_dark"
          ],
          "required": true,
          "description": "Current time of day"
        },
        "target_time": {
          "type": "enum",
          "values": [
            "pre_dawn",
            "sunrise_golden",
